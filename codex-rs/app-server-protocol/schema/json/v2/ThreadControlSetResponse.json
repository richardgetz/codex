{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ThreadControl": {
      "properties": {
        "mode": {
          "$ref": "#/definitions/ThreadControlMode"
        },
        "reason": {
          "type": "string"
        },
        "releaseChannel": {
          "type": [
            "string",
            "null"
          ]
        },
        "releasedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "targetThreadIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "threadId": {
          "type": "string"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        },
        "watchIntervalSeconds": {
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "mode",
        "reason",
        "targetThreadIds",
        "threadId",
        "updatedAt"
      ],
      "type": "object"
    },
    "ThreadControlMode": {
      "enum": [
        "continuous",
        "router"
      ],
      "type": "string"
    }
  },
  "properties": {
    "control": {
      "$ref": "#/definitions/ThreadControl"
    }
  },
  "required": [
    "control"
  ],
  "title": "ThreadControlSetResponse",
  "type": "object"
}