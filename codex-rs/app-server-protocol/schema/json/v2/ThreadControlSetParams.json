{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ThreadControlMode": {
      "enum": [
        "continuous",
        "orchestrator"
      ],
      "type": "string"
    }
  },
  "properties": {
    "mode": {
      "$ref": "#/definitions/ThreadControlMode"
    },
    "reason": {
      "type": "string"
    },
    "releaseChannel": {
      "type": [
        "string",
        "null"
      ]
    },
    "targetThreadIds": {
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "threadId": {
      "type": "string"
    },
    "watchIntervalSeconds": {
      "format": "uint32",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    }
  },
  "required": [
    "mode",
    "reason",
    "threadId"
  ],
  "title": "ThreadControlSetParams",
  "type": "object"
}